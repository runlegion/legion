#!/bin/bash
# Pre-commit: enforce version invariants, then run /simplify on staged changes.
#
# Step 1 (always runs): scripts/sync-version.sh when any of Cargo.toml,
#   plugin.json, marketplace.json, or plugin/CHANGELOG.md are staged.
#   Cargo.toml is the source of truth for the version number. The script
#   propagates Cargo.toml's version to plugin.json and marketplace.json (and
#   stages the updates), refuses to downgrade if either is ahead of Cargo.toml,
#   and requires plugin/CHANGELOG.md's top "## <version>" header to match.
#   See scripts/sync-version.sh and runlegion/legion#210.
#
# Step 2: run Claude Code's /simplify on the staged diff to catch structural
#   issues, dead code, and cleanup before every commit. Skipped silently if
#   Claude Code is unavailable, disabled, or does not answer within
#   CLAUDE_REVIEW_TIMEOUT_SECS.

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Bounds the nested `claude -p` review so a wedged or slow child can never
# hang the commit. Stock macOS ships bash without GNU coreutils' `timeout`,
# so this uses the background-process + watchdog pattern: `set -m` puts the
# backgrounded claude invocation in its own process group, so the watchdog
# can signal the whole group (including any grandchildren claude spawns,
# e.g. MCP servers) instead of leaving orphans that keep a terminal wedged.
CLAUDE_REVIEW_TIMEOUT_SECS=120

# run_claude_review PROMPT INPUT_FILE OUTPUT_FILE
#
# Runs `claude -p PROMPT < INPUT_FILE > OUTPUT_FILE`, killing the whole
# process group if it runs past CLAUDE_REVIEW_TIMEOUT_SECS. Sets
# LEGION_SKIP_STOP_BLOCK=1 on the child so a healthy claude invocation can
# exit on its own instead of being held open by legion's Stop gate when this
# hook fires from inside an agent session. Returns the child's exit status;
# a killed-for-timeout child reports a nonzero status like any other failure,
# so callers only need one failure branch.
run_claude_review() {
  local prompt="$1"
  local input_file="$2"
  local output_file="$3"
  (
    set -m
    LEGION_SKIP_STOP_BLOCK=1 claude -p "$prompt" <"$input_file" >"$output_file" 2>/dev/null &
    local claude_pid=$!
    (
      sleep "$CLAUDE_REVIEW_TIMEOUT_SECS"
      kill -TERM -"$claude_pid" 2>/dev/null
      sleep 2
      kill -KILL -"$claude_pid" 2>/dev/null
    ) &
    local watchdog_pid=$!
    wait "$claude_pid" 2>/dev/null
    local status=$?
    # The watchdog is itself a process-group leader under `set -m`; kill its
    # group (not just its own pid) so a still-sleeping timer does not linger
    # as an orphan on the fast path where claude finishes before timing out.
    kill -- -"$watchdog_pid" 2>/dev/null
    wait "$watchdog_pid" 2>/dev/null
    exit "$status"
  )
}

# Step 1: version sync. Only runs when a version-bearing file is staged;
# noise-free on every other commit.
STAGED=$(git diff --cached --name-only)
if echo "$STAGED" | grep -qE '^(Cargo\.toml|plugin/\.claude-plugin/plugin\.json|\.claude-plugin/marketplace\.json|plugin/CHANGELOG\.md)$'; then
  if ! "${REPO_ROOT}/scripts/sync-version.sh"; then
    echo "[pre-commit] scripts/sync-version.sh failed -- fix the version/changelog and re-commit" >&2
    exit 1
  fi
fi

# Step 2: simplify review on the staged diff.
DIFF=$(git diff --cached --diff-filter=ACMR)
if [ -z "$DIFF" ]; then
  exit 0
fi

echo "[pre-commit] Running simplify review on staged changes..."

DIFF_FILE=$(mktemp)
RESULT_FILE=$(mktemp)
trap 'rm -f "$DIFF_FILE" "$RESULT_FILE"' EXIT
printf '%s\n' "$DIFF" >"$DIFF_FILE"

run_claude_review "You are reviewing a diff for code quality. Check for: dead code, unnecessary abstractions, copy-paste patterns, missing error handling, and style violations. If you find issues that MUST be fixed before commit, start your response with BLOCK: and list them. If the code is acceptable, start with PASS: and optionally note minor suggestions. Be concise." "$DIFF_FILE" "$RESULT_FILE"
CLAUDE_STATUS=$?

if [ "$CLAUDE_STATUS" -ne 0 ]; then
  echo "[pre-commit] Claude Code unavailable, skipping review"
  exit 0
fi

RESULT=$(cat "$RESULT_FILE")
echo "$RESULT"

if echo "$RESULT" | grep -q "^BLOCK:"; then
  echo ""
  echo "[pre-commit] Review found issues. Fix them and re-commit."
  exit 1
fi

exit 0
