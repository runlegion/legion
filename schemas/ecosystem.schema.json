{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ecosystem",
  "description": "Service-design ecosystem map: actors, channels, value exchanges, moments of truth, and failure modes of a service. Part of the definition layer (legion #526).",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "review", "done"] },
        "date": { "type": "string" },
        "author": { "type": "string" },
        "core_service": { "type": "string" }
      },
      "required": ["title", "status", "date", "author", "core_service"]
    },
    "actors": {
      "type": "object",
      "properties": {
        "primary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "persona": { "type": ["string", "null"], "description": "Persona embodying this actor; null when not yet authored" },
              "role": { "type": "string" },
              "entry_point": { "type": "string" },
              "need": { "type": "string" }
            },
            "required": ["name", "role"]
          }
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "relationship": { "type": "string" }
            },
            "required": ["name", "role"]
          }
        },
        "tertiary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" },
              "relationship": { "type": "string" }
            },
            "required": ["name", "role"]
          }
        }
      },
      "required": ["primary"]
    },
    "channels": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "users": { "type": "string" },
          "purpose": { "type": "string" }
        },
        "required": ["name", "type", "purpose"]
      }
    },
    "value_exchanges": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "gives": { "type": "string" },
          "gets": { "type": "string" }
        },
        "required": ["from", "to", "gives", "gets"]
      }
    },
    "moments_of_truth": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "number": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "actor": { "type": "string" },
          "success": { "type": "string" },
          "failure": { "type": "string" }
        },
        "required": ["number", "title", "actor", "success", "failure"]
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "failure": { "type": "string" },
          "impact": { "type": "string" },
          "recovery": { "type": "string" }
        },
        "required": ["failure", "impact", "recovery"]
      }
    }
  },
  "required": ["meta", "actors", "channels", "value_exchanges", "moments_of_truth"]
}
